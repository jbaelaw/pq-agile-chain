[Unit]
Description=PQ-Agile Chain web service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/pq-agile-chain
Environment=PQ_AGILE_CHAIN_DATA_DIR=/var/lib/pq-agile-chain
ExecStart=/opt/pq-agile-chain/.venv/bin/uvicorn pq_agile_chain.web:app --host 127.0.0.1 --port 8401
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
